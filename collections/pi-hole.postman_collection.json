          "name": "Create a session",
          "request": {
            "name": "Create a session",
            "description": {
              "content": "Authenticate against Pi-hole using the admin password (or an\napplication password) and receive a session identifier (SID) plus\nCSRF token. The SID is then sent on subsequent requests via the\n`X-FTL-SID` header, a `sid` query parameter, the request body, or\na `sid` cookie (cookie requires `X-FTL-CSRF`).\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "auth"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "description": "Hostname or IP of the Pi-hole server.",
                  "type": "any",
                  "value": "{{piHoleHost}}",
                  "key": "piHoleHost"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"<string>\"\n}",
